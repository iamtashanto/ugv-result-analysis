{
  "manifest_version": 3,
  "name": "UGV Result Analysis",
  "version": "0.1.0",
  "description": "What-if GPA simulator, target CGPA planner, trend charts and PDF grade sheet for the UGV student portal.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://ugv.edu.bd/student-dashboard/results*"],
      "js": [
        "src/gradeScale.js",
        "src/parser.js",
        "src/analysis.js",
        "src/pdf.js",
        "src/ui.js",
        "src/content.js"
      ],
      "css": ["src/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "UGV Result Analysis",
    "default_popup": "src/popup.html"
  }
}
